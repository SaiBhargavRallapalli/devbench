{
  "ci": {
    "collect": {
      "startServerCommand": "npm start",
      "startServerReadyPattern": "localhost",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/json",
        "http://localhost:3000/tools/base64-encode"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.5 }],
        "categories:accessibility": ["warn", { "minScore": 0.7 }],
        "categories:best-practices": ["warn", { "minScore": 0.8 }],
        "categories:seo": ["warn", { "minScore": 0.8 }],
        "efficient-animated-content": ["warn", { "maxLength": 0 }],
        "offscreen-images": ["warn", { "maxLength": 0 }],
        "unminified-css": ["warn", { "maxLength": 0 }],
        "unminified-javascript": ["warn", { "maxLength": 0 }],
        "unused-css-rules": ["warn", { "maxLength": 0 }],
        "unused-javascript": ["warn", { "maxLength": 0 }],
        "uses-optimized-images": ["warn", { "maxLength": 0 }],
        "uses-rel-preconnect": ["warn", { "maxLength": 0 }],
        "uses-responsive-images": ["warn", { "maxLength": 0 }],
        "uses-text-compression": ["warn", { "maxLength": 0 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
